# ─── Supabase ───────────────────────────────────────────────
# Create a project at https://supabase.com, then Project Settings → API
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# anon key is safe for the browser; service_role key is server-only (never ship to client)
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Storage bucket for device images (create it in Supabase → Storage)
SUPABASE_IMAGE_BUCKET=device-images

# ─── Server ─────────────────────────────────────────────────
PORT=4000

# ─── Client (Vite) ──────────────────────────────────────────
# URL the React app calls; in dev the Vite proxy points at the server
VITE_API_URL=http://localhost:4000
